{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(pnpm:*)",
      "Bash(pnpm -r build)",
      "Bash(pnpm -r test)",
      "Bash(pnpm -r lint)",
      "Bash(pnpm pxc:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir -p:*)",
      "Bash(chmod +x:*)",
      "Read(**)",
      "Edit(packages/**)",
      "Edit(pixelcreator-devkit/**)",
      "Edit(showcase/**)",
      "Edit(docs/**)",
      "Edit(CLAUDE.md)",
      "Edit(README.md)",
      "Edit(CHANGELOG.md)",
      "Edit(package.json)",
      "Edit(.claude/**)",
      "Edit(.gitignore)",
      "Write(packages/**)",
      "Write(pixelcreator-devkit/**)",
      "Write(showcase/**)",
      "Write(docs/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(git push --force origin main*)",
      "Bash(git push --force origin master*)",
      "Bash(git push -f origin main*)",
      "Bash(git push -f origin master*)",
      "Bash(git reset --hard)",
      "Bash(git clean -fdx*)",
      "Bash(git clean -fxd*)",
      "Bash(*--no-verify*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Read(.env)"
    ]
  },
  "plugins": {
    "pixelcreator-devkit": {
      "path": "./pixelcreator-devkit",
      "enabled": true
    }
  },
  "env": {
    "NODE_ENV": "development"
  }
}
